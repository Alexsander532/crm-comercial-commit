# ================================================================
# CRM Comercial — Environment Variables (example)
# ================================================================
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env

# --- Database ---
DB_URL=jdbc:postgresql://db.seu-projeto.supabase.co:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=sua-senha-aqui

# --- JWT ---
JWT_SECRET=sua-chave-secreta-jwt-aqui
JWT_EXPIRATION=86400000

# --- Server ---
SERVER_PORT=8080
